{
    "name": "kkt/pizza231",
    "description": "Пиццерия на PHP с использованием MVC",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "phpmailer/phpmailer": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "nunomaduro/phpinsights": "^2.13"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Test\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8000"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
